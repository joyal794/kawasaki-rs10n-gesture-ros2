<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot_box_test">

  <link name="world"/>

  <link name="box_link">
    <visual>
      <origin xyz="0 0 1" rpy="0 0 0"/>
      <geometry>
        <box size="1 1 1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="world_to_box" type="fixed">
    <parent link="world"/>
    <child link="box_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>
