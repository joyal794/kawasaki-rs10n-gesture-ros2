<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rs10n">

  <!-- ========================= -->
  <!-- BASE LINK                 -->
  <!-- ========================= -->
  <link name="base_link">
  <visual>
    <geometry>
      <mesh filename="package://rs10n_description/meshes/base.stl" scale="0.01 0.01 0.01"/>
    </geometry>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </visual>
</link>

  <!-- ========================= -->
  <!-- LINK 1                    -->
  <!-- ========================= -->
  <link name="link_1">
  <visual>
    <geometry>
      <mesh filename="package://rs10n_description/meshes/link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </visual>
</link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="100" velocity="4.36"/>
  </joint>

  <!-- ========================= -->
  <!-- LINK 2                    -->
  <!-- ========================= -->
  <link name="link_2">
  <visual>
    <geometry>
      <mesh filename="package://rs10n_description/meshes/link_2.stl" scale="0.01 0.01 0.01"/>
    </geometry>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </visual>
</link>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.40" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8326" upper="2.5307" effort="100" velocity="4.36"/>
  </joint>

  <!-- ========================= -->
  <!-- LINK 3                    -->
  <!-- ========================= -->
  <link name="link_3">
  <visual>
    <geometry>
      <mesh filename="package://rs10n_description/meshes/link_3.stl" scale="0.01 0.01 0.01"/>
    </geometry>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </visual>
</link>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.70" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.8449" upper="2.6180" effort="100" velocity="3.75"/>
  </joint>

  <!-- ========================= -->
  <!-- LINK 4                    -->
  <!-- ========================= -->
  <link name="link_4">
  <visual>
    <geometry>
      <mesh filename="package://rs10n_description/meshes/link_4.stl" scale="0.01 0.01 0.01"/>
    </geometry>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </visual>
</link>

  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0.60" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-4.7124" upper="4.7124" effort="100" velocity="6.37"/>
  </joint>

  <!-- ========================= -->
  <!-- LINK 5                    -->
  <!-- ========================= -->
 <link name="link_5">
  <visual>
    <geometry>
      <mesh filename="package://rs10n_description/meshes/link_5.stl" scale="0.01 0.01 0.01"/>
    </geometry>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </visual>
</link>

  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5307" upper="2.5307" effort="100" velocity="6.63"/>
  </joint>

  <!-- ========================= -->
  <!-- LINK 6                    -->
  <!-- ========================= -->
 <link name="link_6">
  <visual>
    <geometry>
      <mesh filename="package://rs10n_description/meshes/link_6.stl" scale="0.01 0.01 0.01"/>
    </geometry>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </visual>
</link>
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2832" upper="6.2832" effort="100" velocity="12.21"/>
  </joint>

  <!-- ========================= -->
  <!-- TOOL0 FRAME               -->
  <!-- ========================= -->
  <!-- This is not a gripper. It is only the robot wrist reference point. -->
  <link name="tool0"/>

  <joint name="tool0_fixed" type="fixed">
    <parent link="link_6"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- SIMPLE PROCESS TABLE      -->
  <!-- ========================= -->
  <link name="process_table">
    <visual>
      <geometry>
        <box size="1.0 0.6 0.05"/>
      </geometry>
      <origin xyz="0.8 0 0.2" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="process_table_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="process_table"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- PROCESS POINT 1           -->
  <!-- ========================= -->
  <link name="process_point_1">
    <visual>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <origin xyz="0.65 0.15 0.28" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="process_point_1_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="process_point_1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- PROCESS POINT 2           -->
  <!-- ========================= -->
  <link name="process_point_2">
    <visual>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <origin xyz="0.85 -0.15 0.28" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="process_point_2_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="process_point_2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>
